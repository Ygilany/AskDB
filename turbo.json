{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build", "^lint"],
      "outputs": []
    }
  }
}
