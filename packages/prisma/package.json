{
  "name": "@askdb/prisma",
  "version": "0.2.0-beta.7",
  "description": "AskDB Prisma integration: schema-file introspection connector for Prisma schemas.",
  "keywords": [
    "askdb",
    "prisma",
    "schema-v2",
    "introspection",
    "nl-to-sql"
  ],
  "homepage": "https://github.com/Ygilany/AskDB#readme",
  "bugs": {
    "url": "https://github.com/Ygilany/AskDB/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ygilany/AskDB.git",
    "directory": "packages/prisma"
  },
  "license": "Apache-2.0",
  "author": "Yahya Gilany",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@askdb/introspect": "workspace:*",
    "@prisma/internals": "^7.8.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
