{
  "name": "@askdb/sqlite",
  "version": "0.1.0-beta.6",
  "description": "AskDB SQLite integration: introspection connector via sqlite_master + PRAGMA functions and a better-sqlite3-backed catalog query runner. Pairs with @askdb/core's SQLITE_DIALECT.",
  "keywords": [
    "askdb",
    "sqlite",
    "nl-to-sql",
    "natural-language-to-sql",
    "schema-v2",
    "introspection",
    "better-sqlite3"
  ],
  "homepage": "https://github.com/Ygilany/AskDB#readme",
  "bugs": {
    "url": "https://github.com/Ygilany/AskDB/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ygilany/AskDB.git",
    "directory": "packages/sqlite"
  },
  "license": "Apache-2.0",
  "author": "Yahya Gilany",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@askdb/core": "workspace:*",
    "@askdb/introspect": "workspace:*"
  },
  "peerDependencies": {
    "better-sqlite3": ">=11"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.5.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
