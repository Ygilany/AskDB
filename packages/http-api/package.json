{
  "name": "@askdb/http-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "askdb-http": "./dist/bin.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bin.js",
    "dev": "pnpm build && pnpm start",
    "dev:watch": "tsx watch src/bin.ts",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.21",
    "@askdb/core": "workspace:*",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "tsx": "^4.20.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}

