{
  "name": "@askdb/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.21",
    "ai": "^4.3.19",
    "pino": "^9.6.0",
    "zod": "^3.24.4"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.11.12",
    "pg": "^8.14.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
