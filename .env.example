# Copy to `.env` for local development (do not commit `.env`).
# First-party apps load `.env`, then merge `askdb.config.*` / `.config/askdb.*` when present (`@askdb/config`).
# For an `askdb.config.ts` starter with example `.env` keys in comments, run: `pnpm exec askdb init`

# ─────────────────────────────────────────────────────────────────────────────
# AI provider configuration  (BYO LLM keys — choose ONE stanza below)
# ─────────────────────────────────────────────────────────────────────────────
# AskDB is provider-agnostic. The `ASKDB_AI_PROVIDER` selector decides which
# provider to construct. Each provider has its own native env var names. The
# `ASKDB_AI_*` family is a universal alias set that takes precedence and works
# across providers — handy when you want a single naming convention.

# Provider selector: openai (default) | azure | google
# `azure` also accepts the aliases `azure-openai` and `foundry`.
ASKDB_AI_PROVIDER=openai

# ─────────────────────────────────────────────────────────────────────────────
# Stanza A — OpenAI (or any OpenAI-compatible endpoint)
# ─────────────────────────────────────────────────────────────────────────────
# used when ASKDB_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Also works for: OpenRouter, Together, Groq, vLLM, LM Studio, llama.cpp server,
# Foundry's `/openai/v1` inference route — anything that speaks the OpenAI REST
# protocol. Just set OPENAI_BASE_URL to the endpoint.
# OPENAI_BASE_URL=                       # e.g. https://api.openai.com/v1 (default)

# ─────────────────────────────────────────────────────────────────────────────
# Stanza B — Azure OpenAI / Microsoft Foundry
# ─────────────────────────────────────────────────────────────────────────────
# used when ASKDB_AI_PROVIDER=azure
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_KEY_SECONDARY=
#
# AZURE_OPENAI_DEPLOYMENT=gpt-      # the *deployment* name you created
# AZURE_OPENAI_API_VERSION=2024-10-21      # whatever your deployment supports
#
# For Foundry inference endpoints (URL like .services.ai.azure.com/openai/deployments/<deployment_name>)
# you can skip the resource name and set the full URL instead:
# AZURE_OPENAI_BASE_URL=https://.../openai/deployments
# OR set up the resource name
# ASKDB_AI_AZURE_RESOURCE_NAME=          # the subdomain, e.g. "my-foundry" for https://my-foundry.openai.azure.com

# ─────────────────────────────────────────────────────────────────────────────
# Stanza C — Google Gemini
# ─────────────────────────────────────────────────────────────────────────────
# used when ASKDB_AI_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=
# ASKDB_AI_MODEL=gemini-2.0-flash       # or gemini-1.5-pro, gemini-2.5-pro, etc.
# GOOGLE_AI_BASE_URL=                   # optional: override the Gemini API endpoint

# ─────────────────────────────────────────────────────────────────────────────
# Database  (BYO — only required for live Postgres introspection)
# ─────────────────────────────────────────────────────────────────────────────
# Database URL to introspect the database
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/pagila

# Optional: required when using the RAG pgvector store
# ASKDB_PGVECTOR_URL=postgres://postgres:postgres@127.0.0.1:5434/askdb_rag
# Optional: ivfflat | hnsw | none (default hnsw) — emitted when flattening pgvector from askdb.config
# ASKDB_PGVECTOR_INDEX_STRATEGY=hnsw

# Optional: Studio RAG embedder. Defaults to the configured AskDB AI SDK
# connection when an embedding-capable key is configured, otherwise falls back
# to a local mock lexical embedder.
# ASKDB_RAG_EMBEDDER=mock
# ASKDB_RAG_EMBEDDER=ai-sdk
# ASKDB_RAG_EMBEDDER=openai                 # compatibility alias for AI SDK OpenAI
# Uses the configured AskDB AI connection URL (ASKDB_AI_BASE_URL / provider-native base URL).
# ASKDB_RAG_EMBEDDER_MODEL=text-embedding-3-small
# ASKDB_RAG_EMBEDDER_DIMENSIONS=1536
# Azure/Foundry can use a separate embedding deployment/model name from the chat deployment:
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Optional: Phase 2 structured logs (Pino JSON lines). Default silent unless CLI flags imply info.
# ASKDB_LOG_LEVEL=info
# ASKDB_CORRELATION_ID=

# Optional: Phase 2 operating mode — schema_only | bounded_results (see docs/contracts/modes-v1.md)
# ASKDB_MODE=schema_only

# Optional: omit sensitive table/column *names* from NL→SQL DDL (default: include names, tagged sensitive)
# ASKDB_OMIT_SENSITIVE_FROM_PROMPT=true

# Optional (HTTP API / other hosts): default schema configured server-side
# ASKDB_SCHEMA_PATH=fixtures/schemas/orders-users.schema.json
# ASKDB_SCHEMA_JSON={"version":1,"tables":[...]}  # prefer ASKDB_SCHEMA_PATH
