---
const steps = [
  {
    number: "01",
    title: "Author your schema",
    body: "Introspect your database, then enrich the schema with descriptions, aliases, sensitive markers, and tenant policy in Studio. Commit it like code.",
  },
  {
    number: "02",
    title: "Ask in natural language",
    body: "Call ask() from your app — or POST to the HTTP API. AskDB grounds the question in your schema, generates SQL, and validates every clause.",
  },
  {
    number: "03",
    title: "Your app runs the SQL",
    body: "AskDB returns validated SQL with parameters. Your application logs it, approves it, runs it through your own pool, and shows the result to the user.",
  },
];
---

<ol class="home-workflow" aria-label="The three steps of using AskDB">
  {steps.map((step) => (
    <li class="home-workflow-step">
      <span class="home-workflow-number" aria-hidden="true">{step.number}</span>
      <h3>{step.title}</h3>
      <p>{step.body}</p>
    </li>
  ))}
</ol>
