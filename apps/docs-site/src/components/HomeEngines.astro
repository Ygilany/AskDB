---
const engines = [
  {
    name: "PostgreSQL",
    pkg: "@askdb/postgres",
    note: "Reference dialect — new features land here first.",
  },
  {
    name: "MySQL",
    pkg: "@askdb/mysql",
    note: "First-class dialect and introspection.",
  },
  {
    name: "SQLite",
    pkg: "@askdb/sqlite",
    note: "First-class dialect — embedded and file-backed, great for dev and tests.",
  },
  {
    name: "SQL Server",
    pkg: "@askdb/sqlserver",
    note: "First-class T-SQL dialect and introspection.",
  },
];
---

<div class="home-engines">
  {engines.map((engine) => (
    <article class="home-engine-card">
      <h3>{engine.name}</h3>
      <code class="home-engine-pkg">{engine.pkg}</code>
      <p>{engine.note}</p>
    </article>
  ))}
</div>
