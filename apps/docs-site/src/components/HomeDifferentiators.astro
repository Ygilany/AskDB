---
const items = [
  {
    title: "Your data never touches the model",
    body: "AskDB sends the question and your schema artifact — never your rows, your credentials, or your query results. The model writes SQL blind to your data.",
    icon: "shield",
  },
  {
    title: "Reviewed schema, your app runs the SQL",
    body: "Your team authors and reviews the schema context. AskDB returns SQL — your application chooses whether to log it, approve it, or run it.",
    icon: "review",
  },
  {
    title: "Safety guardrails on every query",
    body: "Every generated query is parsed, scoped, and rejected if it violates the rules your schema declares — read-only, tenant filters, sensitive columns.",
    icon: "guard",
  },
  {
    title: "You own the infrastructure and the context",
    body: "AskDB is a library you wire into your stack. Your model key, your database, your vector store. The schema artifact is a file you commit, not a black box.",
    icon: "stack",
  },
];
---

<div class="home-bento home-differentiators">
  {items.map((item) => (
    <article class="home-bento-card">
      <div class="home-bento-icon" aria-hidden="true">
        {item.icon === "shield" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 5 6v6c0 4.5 3 8.5 7 9 4-.5 7-4.5 7-9V6l-7-3Z" />
            <path d="m9 12 2 2 4-4" />
          </svg>
        )}
        {item.icon === "review" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="16" height="16" rx="2" />
            <path d="M8 10h8M8 14h5" />
            <circle cx="17" cy="15" r="2.5" />
            <path d="m20 18-1.6-1.6" />
          </svg>
        )}
        {item.icon === "guard" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v4" />
            <path d="M4 8h16l-1.2 8.5a3 3 0 0 1-3 2.5H8.2a3 3 0 0 1-3-2.5L4 8Z" />
            <path d="m9 13 2 2 4-4" />
          </svg>
        )}
        {item.icon === "stack" && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="5" rx="1" />
            <rect x="3" y="11" width="18" height="5" rx="1" />
            <rect x="3" y="18" width="18" height="3" rx="1" />
            <path d="M7 6.5h.01M7 13.5h.01" />
          </svg>
        )}
      </div>
      <h3>{item.title}</h3>
      <p>{item.body}</p>
    </article>
  ))}
</div>
