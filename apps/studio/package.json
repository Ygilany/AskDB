{
  "name": "@askdb/studio",
  "version": "0.1.0",
  "description": "AskDB Studio: local browser UI for Schema v2 enrichment and sample NL-to-SQL checks.",
  "keywords": [
    "askdb",
    "studio",
    "schema",
    "schema-v2",
    "enrichment",
    "nl-to-sql"
  ],
  "homepage": "https://github.com/Ygilany/AskDB#readme",
  "bugs": {
    "url": "https://github.com/Ygilany/AskDB/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ygilany/AskDB.git",
    "directory": "apps/studio"
  },
  "license": "Apache-2.0",
  "author": "Yahya Gilany",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "askdb-studio": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/bin.js",
    "dev": "pnpm build && pnpm start",
    "lint": "tsc -p tsconfig.build.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.21",
    "@askdb/core": "workspace:*",
    "@askdb/postgres": "workspace:*",
    "@askdb/rag": "workspace:*",
    "@askdb/tui": "workspace:*",
    "ai": "^4.3.19"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
