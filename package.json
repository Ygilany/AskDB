{
  "name": "askdb",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "vitest",
    "lint": "turbo run lint",
    "docs:build": "pnpm -C apps/docs-site build",
    "docs:dev": "pnpm -C apps/docs-site dev",
    "pagila:up": "docker compose -f fixtures/pagila/docker-compose.yml up --build -d",
    "pagila:down": "docker compose -f fixtures/pagila/docker-compose.yml down",
    "pagila:logs": "docker compose -f fixtures/pagila/docker-compose.yml logs -f",
    "pagila:reset": "docker compose -f fixtures/pagila/docker-compose.yml down -v",
    "pgvector:up": "docker compose -f fixtures/pgvector/docker-compose.yml up -d",
    "pgvector:down": "docker compose -f fixtures/pgvector/docker-compose.yml down",
    "pgvector:logs": "docker compose -f fixtures/pgvector/docker-compose.yml logs -f",
    "pgvector:reset": "docker compose -f fixtures/pgvector/docker-compose.yml down -v",
    "pgvector:test": "ASKDB_PGVECTOR_URL=postgres://postgres:postgres@127.0.0.1:5434/askdb_rag pnpm --filter @askdb/rag exec vitest run --config ../../vitest.config.ts src/stores/pgvector.integration.test.ts",
    "smoke:install": "bash examples/installable-smoke/run.sh",
    "preflight": "bash scripts/release-preflight.sh",
    "changeset": "changeset",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@askdb/cli": "workspace:*",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.13.14",
    "turbo": "^2.5.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.9"
  }
}
